# .env  (local development only — never commit this file)
TELEGRAM_TOKEN=your-telegram-bot-token-here
GEMINI_API_KEY=your-gemini-api-key-here

# Azure SQL ODBC connection string
# Get this from Azure Portal → SQL Database → Connection Strings → ODBC
AZURE_SQL_CONN=DRIVER={ODBC Driver 18 for SQL Server};SERVER=your-server.database.windows.net;DATABASE=spendbot;UID=sqladmin;PWD=your-password;Encrypt=yes;TrustServerCertificate=no
